{
  "name": "@azmr/ai",
  "version": "0.1.0",
  "description": "AI auto-fix system with isolated-vm sandboxing — safe code execution and analysis",
  "type": "module",
  "license": "MIT",
  "author": "Alshafaraz Gazi <alshafaraz.gazi@gmail.com>",
  "homepage": "https://docs.azmara.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azmara-labs/platform.git",
    "directory": "packages/ai"
  },
  "keywords": [
    "ai",
    "auto-fix",
    "sandbox",
    "isolated-vm",
    "security",
    "azmara"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/security": "workspace:*"
  },
  "optionalDependencies": {
    "isolated-vm": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "notes": {
    "isolated-vm": "Requires node-gyp native compilation. On Windows: install Visual Studio Build Tools + Python. See: https://github.com/nicolo-ribaudo/isolated-vm"
  }
}
