{
  "name": "@azmr/core",
  "version": "0.0.2",
  "description": "Reactive engine — signals, effects, computed values",
  "type": "module",
  "license": "MIT",
  "author": "Alshafaraz Gazi <alshafaraz.gazi@gmail.com>",
  "homepage": "https://docs.azmara.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azmara-labs/platform.git",
    "directory": "packages/core"
  },
  "keywords": [
    "reactive",
    "signals",
    "computed",
    "effects",
    "state-management",
    "azmara"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  }
}
