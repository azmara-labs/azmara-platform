{
  "name": "@azmr/playground",
  "version": "0.0.1",
  "private": true,
  "description": "Playground app — develop and test Azmara platform packages",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "vite",
    "build": "tsup src/index.ts --format esm --clean",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@azmr/core": "workspace:*",
    "@azmr/db": "workspace:*",
    "@azmr/query": "workspace:*",
    "@azmr/security": "workspace:*",
    "@azmr/ui": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
