{
  "name": "azmara-platform",
  "private": true,
  "version": "0.0.1",
  "description": "Azmara — modern data-first application runtime",
  "license": "MIT",
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "audit:deps": "pnpm audit --audit-level=high --ignore-registry-errors",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
